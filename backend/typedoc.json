{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeNotDocumented": true,
  "includeVersion": true,
  "hideGenerator": true,
  "categorizeByGroup": true,
  "theme": "default",
  "name": "Framework Documentation"
}